<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="4dp"
    app:cardCornerRadius="8dp"
    app:cardElevation="2dp">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="16dp">

        <TextView
            android:id="@+id/text_fine_id"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="Fine #F001"
            android:textSize="16sp"
            android:textStyle="bold"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintEnd_toStartOf="@+id/text_fine_status" />

        <TextView
            android:id="@+id/text_fine_status"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="UNPAID"
            android:textSize="12sp"
            android:textStyle="bold"
            android:background="@drawable/status_badge_background"
            android:padding="4dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <TextView
            android:id="@+id/text_fine_type"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="Speeding"
            android:textSize="14sp"
            android:layout_marginTop="4dp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/text_fine_id"
            app:layout_constraintEnd_toEndOf="parent" />

        <TextView
            android:id="@+id/text_fine_date"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="2024-11-20"
            android:textSize="12sp"
            android:layout_marginTop="4dp"
            android:textColor="@android:color/darker_gray"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/text_fine_type" />

        <TextView
            android:id="@+id/text_fine_amount"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="RWF 50,000"
            android:textSize="14sp"
            android:textStyle="bold"
            android:layout_marginTop="4dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toBottomOf="@id/text_fine_type" />

    </androidx.constraintlayout.widget.ConstraintLayout>

</androidx.cardview.widget.CardView>
